import telebot
import joblib
import numpy as np

# 1. Ваши настройки
TOKEN = '8430477295:AAff-WmDwnH...' # Используйте ваш токен из BotFather
bot = telebot.TeleBot(TOKEN)

# 2. Загрузка модели
model = joblib.load('churn_model.pkl')

# Временное хранилище данных пользователей
user_data = {}

@bot.message_handler(commands=['start'])
def start(message):
    bot.send_message(message.chat.id, "Привет! Я помогу предсказать отток клиента. Введите стаж клиента (в месяцах):")
    user_data[message.chat.id] = []

@bot.message_handler(func=lambda message: True)
def handle_input(message):
    chat_id = message.chat.id
    if chat_id not in user_data:
        return

    try:
        val = float(message.text)
        user_data[chat_id].append(val)
        
        if len(user_data[chat_id]) == 1:
            bot.send_message(chat_id, "Введите ежемесячный платеж:")
        elif len(user_data[chat_id]) == 2:
            bot.send_message(chat_id, "Техподдержка (1 - да, 0 - нет):")
        elif len(user_data[chat_id]) == 3:
            # Делаем предсказание
            data = np.array([user_data[chat_id]])
            prediction = model.predict(data)[0]
            
            result = "Клиент может уйти 😟" if prediction == 1 else "Клиент останется с нами! 😊"
            bot.send_message(chat_id, f"Результат прогноза: {result}")
            del user_data[chat_id] # Очищаем данные
            
    except ValueError:
        bot.send_message(chat_id, "Пожалуйста, введите число.")

bot.polling(none_stop=True)
