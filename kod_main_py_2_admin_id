# Загружаем данные из секретов
TOKEN = os.getenv("BOT_TOKEN")
ADMIN_ID = os.getenv("ADMIN_ID") 

# Пример функции, которая отвечает только вам
@dp.message(Command("admin"))
async def admin_panel(message: types.Message):
    if str(message.from_user.id) == ADMIN_ID:
        await message.answer("Добро пожаловать в панель управления, Акнабат!")
    else:
        await message.answer("Извините, эта команда только для администратора.")
